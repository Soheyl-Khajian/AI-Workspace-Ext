{
  "manifest_version": 3,
  "name": "AI Workspace",
  "version": "0.1.0",
  "description": "Your local AI Workspace",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["https://chatgpt.com/*"],
  "background": {
    "service_worker": "dist/background/serviceWorker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["dist/content/bootstrap.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/ui/floatingShell.html",
        "dist/ui/floatingShell.css",
        "dist/ui/root.css",
        "dist/ui/orb.css",
        "dist/ui/actions.css",
        "dist/ui/panels.css"
      ],
      "matches": ["https://chatgpt.com/*"]
    }
  ],
  "icons": {
    "128": "icons/icon.png"
  }
}
